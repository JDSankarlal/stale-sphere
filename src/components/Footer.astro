---
<div class="footer">
    <div class="contact">
        <a href="tel:+15199958331" class="contact-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span>(519) 995-8331</span>
        </a>
        <a href="mailto:alex.ilijoski@hotmail.com" class="contact-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span>alex.ilijoski@hotmail.com</span>
        </a>
    </div>

    <div class="socials">
        {socials.map((s) => (
            <a href={s.url} class="social" aria-label={s.name} target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={s.path}></path>
                </svg>
            </a>
        ))}
    </div>

    <p>&copy; {year} Alex Ilijoski. All rights reserved.</p>
    <p>Ready to Work</p>
</div>

<style>
    .footer {
        margin-top: 2rem;
        padding: 1.5rem 2rem;
        background-color: var(--header-bg-color);
        border-top: 1px solid #e0e0e0;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
    }

    .contact {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem 1.5rem;
    }

    .contact-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-public);
        color: #5c5852;
        text-decoration: none;
        font-size: 0.9rem;
    }

    .contact-link svg {
        width: 18px;
        height: 18px;
    }

    .contact-link:hover {
        color: #2563eb;
    }

    .socials {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }

    .social {
        color: #5c5852;
        transition: color 0.2s ease;
    }

    .social svg {
        width: 22px;
        height: 22px;
        display: block;
    }

    .social:hover {
        color: #2563eb;
    }

    .footer p {
        margin: 0;
        font-family: var(--font-public);
        color: #5c5852;
        font-size: 0.9rem;
    }
</style>
