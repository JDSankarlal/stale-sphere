---
const pages = import.meta.glob<{pageTitle: string}>('../pages/*.astro', {eager:true});
const links = Object.entries(pages).map(([filePath, module]) => {
    const name = filePath.replace('../pages/','').replace('.astro','');
    const href = name === 'index' ? '/' : `/${name}`;
    return { name, href, title: module.pageTitle};
});
links.sort((a, b) => (a.href === '/' ? -1 : b.href === '/' ? 1 : 0));
---
<nav>
    <div class="candidate-name">
        <h1> Alex Ilijoski </h1>
        <h2> Ready to Work </h2>
    </div>
    
    <ul>
        {links.map((link) => (
            <li>
                <a href = {link.href}>{link.title}</a>
            </li>
        ))}
    </ul>
    <a href="/volunteer" class="cta-button">Get a Lawn Sign →</a>
</nav>

<style>

    .candidate-name
    {
        display:flex;
        flex-direction: column;
        align-items:flex-start;
        flex-shrink: 1;
    }
    
    nav {
        display: flex;
        align-items: center;
        padding: 0.75rem 2rem;
        background-color: var(--header-bg-color);
        border-bottom: 1px solid #e0e0e0;
        margin-bottom: 2rem;
        width: 100;
    }

     ul {
        display: flex;
        list-style: none;
        gap: 6rem;
        font-weight: 700;
        flex: 1;
        justify-content: center;
    }

    .cta-button {
        background-color: #2563eb;
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 5px;
        text-decoration: none;
        white-space: nowrap;
        font-family: var(--font-public);
        transition: background-color 0.2s ease;
        margin-left: auto;
    }

    .cta-button:hover {
        background-color: color-mix(in srgb, #2563eb, black 15%);
    }

    h1, h2 {
        margin:0;
        padding:0;
    }

    li, a {
        font-family: var(--font-public);
        text-decoration: none;
        background-size:100%;
        transition: all 0.5s ease;
    }

    li:hover a{
        border-radius: 5em;
        background-color: var(--body-bg-color);
        padding: 0.6em 1.5em;
    }


</style>