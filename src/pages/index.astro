---
import CampaignBlock from '../components/CampaignBlock.astro';
import Layout from '../layouts/Layout.astro';
import '../styles/global.css'
export const pageTitle = "Home"
// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
    <div class = "card-grid">
        <CampaignBlock title = "[CAMPAIGN SLOGAN", blockText = "Lorem impsum", imageUrl="https://placehold.co/425x250", imageAlt="Placeholder", imageW="425", imageH="250", imageClass="hero-image">
           <div class="button-group">
               <button class="hero-button" type="button">Get a Lawn Sign</button>
               <button class="hero-button sec" type="button">Donate</button>
            </div>
        </CampaignBlock>
        <CampaignBlock title = "Meet Alex", blockText = "Alex is fighting for you!" />
        <CampaignBlock title = "About", blockText = "Learn more about Alex's background and experience." />
        <CampaignBlock title = "The Platform", blockText = "Find out where Alex stands on the issues that matter to you." />
        <CampaignBlock title = "Contact", blockText = "Get in touch with the campaign team." />
        <CampaignBlock title = "Volunteer", blockText = "Join the campaign and help get out the vote." />
    </div>
</Layout>

<style>
     
    .button-group{
        display:flex;
        gap: 25px;
    }

    .hero-button {
        background-color: rgb(0.55 0.12 250);
        color: white;
        border: none;
        border-radius: 5px;
        padding: 1em;
        margin-top: 1em;
        font-family: var(--font-public);
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        cursor: default;
        white-space: nowrap;
        transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .hero-button:hover {
        background-color: color-mix(in srgb, rgb(0.55 0.12 250), black 15%);
    }

    .hero-button.sec {
        background-color: transparent;
        border: 2px solid #33312c;
        color: #33312c;
    }

    .hero-button.sec:hover {
        background-color: rgba(51, 49, 44, 0.1);
        border-color: color-mix(in srgb, #33312c, black 20%);
        color: color-mix(in srgb, #33312c, black 20%);
    }

    .card-grid {
        display: grid;
        max-width: 90%;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin: 0 auto;
    }

    .card-grid :global(.hero-image)
    {
        float: right;
    }
    .card-grid > :global(:nth-child(1))
    {
        grid-column: span 3;
        
    }
    .card-grid > :global(:nth-child(2))
    {
        grid-column: span 1;
    }

    .card-grid > :global(:nth-child(3))
    {
        grid-column: 1;
    }

     .card-grid > :global(:nth-child(4))
    {
        grid-column: span 3;
        grid-row: span 3;
    }

     .card-grid > :global(:nth-child(5))
    {
        grid-column: 1;
    }

      .card-grid > :global(:nth-child(6))
    {
        grid-column: 1;
    }
   

    @media (max-width: 600px) {
        .card-grid {
            grid-template-columns: 1fr;
        }
        .card-grid > :global(:nth-child(1)),
        .card-grid > :global(:nth-child(2)),
        .card-grid > :global(:nth-child(2n+3)),
        .card-grid > :global(:nth-child(2n+4)) {
            grid-column: span 1;
        }
        
    }

body, h1, h2, h3, h4, p,
figure, blockquote, dl, dd {
    padding:26px 26px 26px 26px;
}


</style>
