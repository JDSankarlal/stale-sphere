---
import CampaignBlock from '../components/CampaignBlock.astro';
import FlatCard from '../components/FlatCard.astro'
import Layout from '../layouts/Layout.astro';
export const pageTitle = "Home";
import alexMain from '../assets/images/alex_main.jpg';
// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout pageTitle={pageTitle}>
    <div class = "card-grid">
        <CampaignBlock title = "Meet Alex", blockText = "Alex and his family moved to Tecumseh due to the unaffordable housing market in Toronto. His family fell in love with the area, its small-town charm, beautiful outdoor spaces, and a close-knit community.", 
        imageUrl={alexMain}, imageAlt="Placeholder", imageW="425", imageH="250", imageClass="hero-image">
             <div class="button-group">
                <a href="/about" class="hero-button sec">Learn More</a>
            </div>
        </CampaignBlock>
          <CampaignBlock title = "Show your support!", blockText = "Request a lawn sign to show your support for Alex's campaign for Tecumseh councillor. Lawn sign delivery will start on August 22nd, 2026.
">
           <div class="button-group">
                <a href="/lawn-sign" class="hero-button">Get a Lawn Sign</a>
                <a href="/donate" class="hero-button sec">Donate</a>
                
            </div>
        </CampaignBlock>
        <CampaignBlock title = "The Platform", blockText = "Find out where Alex stands on the issues that matter to you.">
            <div class = "platform-cards">
                <FlatCard title = "Transparency" href="/platform#transparency" blockText="Transparency and communication with the public is vital. Here's how Alex will communicate with you." />
                <FlatCard title = "Political & Community Engagement" href="/platform#political-community-engagement" blockText="Community is at the heart of municipal government. Read how Alex will reduce barriers so your neighbourhood's voice is heard." />
                <FlatCard title = "Public Transit" href="/platform#public-transit" blockText="Our roads are congested and commute times are long. Read how Alex would advocate for better." />
                <FlatCard title = "Climate Change" href="/platform#climate-change" blockText="Big cities and small towns alike must prepare for climate change. Read Alex's plan to make Tecumseh more resilient." />
                <FlatCard title = "Affordable Housing & Zoning" href="/platform#affordable-housing-zoning" blockText="Updating decades-old zoning laws can unlock affordable housing. Here's Alex's approach to smart, walkable growth." />
                <FlatCard title = "Financial Accountability" href="/platform#financial-accountability" blockText="Keeping taxes stable while running a fiscally responsible budget. See how Alex would manage the town's finances." />
                <FlatCard title = "Outside Investment" href="/platform#outside-investment" blockText="Attracting and retaining investment for the Town of Tecumseh. Read Alex's plan to make use of our location." />
            </div>
        </CampaignBlock>
    </div>
</Layout>

<style>

    body{
        background-color: --body-bg-color;
    }
     
    .button-group{
        display:flex;
        gap: 25px;
    }

    .hero-button {
        background-color: rgb(0.55 0.12 250);
        color: white;
        border: none;
        border-radius: 5px;
        padding: 1em;
        margin-top: 1em;
        font-family: var(--font-public);
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        cursor: default;
        white-space: nowrap;
        transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .hero-button:hover {
        background-color: color-mix(in srgb, rgb(0.55 0.12 250), black 15%);
    }

    .hero-button.sec {
        background-color: transparent;
        border: 2px solid #33312c;
        color: #33312c;
    }

    .hero-button.sec:hover {
        background-color: rgba(51, 49, 44, 0.1);
        border-color: color-mix(in srgb, #33312c, black 20%);
        color: color-mix(in srgb, #33312c, black 20%);
    }

    .card-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .card-grid :global(.hero-image)
    {
        float: right;
    }
    .card-grid > :global(:nth-child(1))
    {
        grid-column: span 3;
        
    }
    .card-grid > :global(:nth-child(2))
    {
        grid-column: span 3;
    }

    .card-grid > :global(:nth-child(3))
    {
        grid-column: span 3;
    }

    .platform-cards
    {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
        width: 100%;
    }

    .platform-cards > :global(section)
    {
        height: 100%;
        margin-top: 0;
    }

    @media (max-width: 600px) {
        .card-grid {
            grid-template-columns: 1fr;
        }
        .card-grid > :global(:nth-child(1)),
        .card-grid > :global(:nth-child(2)),
        .card-grid > :global(:nth-child(2n+3)),
        .card-grid > :global(:nth-child(2n+4)) {
            grid-column: span 1;
        }
        
    }

h1, h2, h3, h4, p,
figure, blockquote, dl, dd {
    padding:26px 26px 26px 26px;
}


</style>
