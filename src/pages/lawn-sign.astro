--- 
import Layout from '../layouts/Layout.astro';
import CampaignBlock from '../components/CampaignBlock.astro';
export const pageTitle = "Lawn Sign";
---
<Layout pageTitle={pageTitle}>
    <CampaignBlock title="Request a Lawn Sign", blockText="Request a lawn sign to show your support for Alex's campaign for Tecumseh councillor. Lawn sign delivery will start on August 22nd, 2026.
    ">
        <form
            name="lawn-sign"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="lawn-form"
        >
            <input type="hidden" name="form-name" value="lawn-sign" />
            <p class="hidden-field">
                <label>Leave this field empty: <input name="bot-field" /></label>
            </p>

            <div class="form-field">
                <label for="first-name">First Name</label>
                <input type="text" id="first-name" name="first-name" required />
            </div>

            <div class="form-field">
                <label for="last-name">Last Name</label>
                <input type="text" id="last-name" name="last-name" required />
            </div>

            <div class="form-field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required />
            </div>

            <div class="form-field">
                <label for="phone">Phone <span class="optional">(optional)</span></label>
                <input type="tel" id="phone" name="phone" />
            </div>

            <div class="form-field">
                <label for="address">Address</label>
                <input type="text" id="address" name="address" required />
            </div>

            <div class="form-field">
                <label for="sign-location">
                    Preferred sign location <span class="optional">(optional)</span>
                </label>
                <input type="text" id="sign-location" name="sign-location" />
            </div>

            <button type="submit" class="submit-button">Request Sign</button>
        </form>
    </CampaignBlock>
</Layout>

<style>
    .lawn-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 1rem;
        max-width: 32rem;
    }

    .form-field {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .form-field label {
        font-family: var(--source-sans-3);
        color: #1a1917;
        font-weight: 600;
        font-size: 0.95rem;
    }

    .optional {
        font-weight: 400;
        color: #5c5852;
    }

    .form-field input {
        font-family: var(--source-sans-3);
        padding: 0.6rem 0.75rem;
        border: 1px solid #e2e7f0;
        border-radius: 8px;
        background-color: var(--body-bg-color);
        color: #1a1917;
    }

    .form-field input:focus {
        outline: 2px solid var(--accent-color);
        outline-offset: 1px;
        border-color: var(--accent-color);
    }

    .submit-button {
        align-self: flex-start;
        background-color: var(--accent-color);
        color: var(--header-bg-color);
        font-family: var(--font-public);
        font-weight: 700;
        padding: 0.6rem 1.5rem;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

    .submit-button:hover {
        background-color: color-mix(in srgb, var(--accent-color), black 15%);
    }

    .hidden-field {
        display: none;
    }
</style>